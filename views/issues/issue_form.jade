extends ../layout

block content
    .d-flex.align-items-center.mb-4
        a.btn.btn-outline-secondary.me-3(href="/assets")
            i.bi.bi-arrow-left
        div
            h1.h3.fw-bold
                i.bi.bi-box-arrow-right.me-2.text-primary
                | Issue Asset
            p.text-muted.mb-0 Assign this asset to an employee

    .row
        .col-lg-8
            .card.border-0.shadow-sm.mb-4
                .card-header.bg-light
                    h6.fw-bold.mb-0
                        i.bi.bi-laptop.me-2
                        | Asset Details
                .card-body
                    .row.g-3
                        .col-md-6
                            label.form-label.small.text-muted Asset ID
                            p.fw-semibold.mb-0
                                code= asset.assetId
                        .col-md-6
                            label.form-label.small.text-muted Name
                            p.fw-semibold.mb-0= asset.name
                        .col-md-6
                            label.form-label.small.text-muted Category
                            p.fw-semibold.mb-0= asset.category ? asset.category.name : '—'
                        .col-md-6
                            label.form-label.small.text-muted Make / Model
                            p.fw-semibold.mb-0
                                if asset.make || asset.model
                                    | #{asset.make || ''} #{asset.model || ''}
                                else
                                    span.text-muted —
                        .col-md-6
                            label.form-label.small.text-muted Serial No.
                            p.fw-semibold.mb-0= asset.serialNumber || '—'
                        .col-md-6
                            label.form-label.small.text-muted Branch
                            p.fw-semibold.mb-0= asset.branch || '—'

            .card.border-0.shadow-sm
                .card-header.bg-light
                    h6.fw-bold.mb-0
                        i.bi.bi-person-check.me-2
                        | Issue To
                .card-body.p-4

                    if errors && errors.length
                        .alert.alert-danger
                            ul.mb-0
                                each err in errors
                                    li= err

                    form(action='/issues/issue/' + asset.id method="POST" novalidate)

                        .mb-3
                            label.form-label.fw-semibold(for="employeeId") Select Employee *
                            select#employeeId.form-select(name="employeeId" required)
                                option(value="" disabled selected) — Select Employee —
                                each emp in employees
                                    option(value=emp.id) #{emp.fullName} — #{emp.department || 'No Dept'}

                        .mb-4
                            label.form-label.fw-semibold(for="issueNotes") Issue Notes
                            textarea#issueNotes.form-control(
                                name="issueNotes"
                                rows="3"
                                placeholder="Optional notes about this issue"
                            )

                        .alert.alert-warning
                            i.bi.bi-exclamation-triangle.me-2
                            | This action will change the asset status to
                            strong  Issued
                            |  and it will no longer appear in stock.

                        .d-flex.gap-2
                            button.btn.btn-primary(type="submit")
                                i.bi.bi-box-arrow-right.me-2
                                | Confirm Issue
                            a.btn.btn-outline-secondary(href="/assets") Cancel