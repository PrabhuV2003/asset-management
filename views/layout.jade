doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title= title || 'Asset Management System'

    //- Bootstrap 5 CDN
    link(rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css")
    //- Bootstrap Icons
    link(rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css")
    //- Custom styles
    link(rel="stylesheet" href="/css/style.css")

  body
    if session && session.userId
      //- ── Navbar ──────────────────────────────────────────
      nav.navbar.navbar-dark.bg-primary.px-4.py-2
        a.navbar-brand.fw-bold(href="/dashboard")
          i.bi.bi-archive-fill.me-2
          | Asset Manager
        .ms-auto.d-flex.align-items-center.gap-3
          span.text-white.small
            i.bi.bi-person-circle.me-1
            = session.userHandle
          span.badge.bg-light.text-primary.text-uppercase.small= session.role.replace(/_/g, ' ')
          a.btn.btn-outline-light.btn-sm(href="/logout")
            i.bi.bi-box-arrow-right.me-1
            | Logout

      //- ── Main Layout ─────────────────────────────────────
      .d-flex(style="min-height: calc(100vh - 56px)")

        //- Sidebar
        nav#sidebar.bg-dark.text-white.py-4(style="width: 240px; min-width: 240px")
          ul.nav.flex-column.px-3
            li.nav-item
              a.nav-link.text-white.active(href="/dashboard" class=(typeof currentPath !== 'undefined' && currentPath ===  '/dashboard' ? 'active' : ''))
                i.bi.bi-speedometer2.me-2
                | Dashboard

            if session.role === 'employee_master' || session.role === 'asset_master'
              li.nav-item.mt-2
                small.text-white-50.text-uppercase.px2(style="font-size:0.7rem") Management
              li.nav-item
                a.nav-link.text-white-50(href="/employees")
                  i.bi.bi-people.me-2
                  | Employees
              li.nav-item
                a.nav-link.text-white-50(href='/categories')
                  i.bi.bi-tags.me-2
                  | Categories
              li.nav-item
                a.nav-link.text-white-50(href="/assets")
                  i.bi.bi-laptop.me-2
                  | Assets
              li.nav-item
                a.nav-link.text-white-50(href='/assets/stock')
                  li.bi.bi-boxes.me-2
                  | Stock View

            if session.role === 'employee'
            li.nav-item.mt-2
              small.text-white-50.text-uppercase.px-2(style="font-size:0.7rem") My Account
              li.nav-item
                a.nav-link.text-white-50(href="#")
                  i.bi.bi-card-checklist.me-2
                  | My Assets

        //- Main content area
        main.flex-grow-1.p-4.bg-light
          //- Flash messages
          if error && error.length
            each msg in error
              .alert.alert-danger.alert-dismissible.fade.show(role="alert")
                i.bi.bi-exclamation-triangle.me-2
                = msg
                button.btn-close(type="button" data-bs-dismiss="alert")

          if success && success.length
            each msg in success
              .alert.alert-success.alert-dismissible.fade.show(role="alert")
                i.bi.bi-check-circle.me-2
                = msg
                button.btn-close(type="button" data-bs-dismiss="alert")

          if info && info.length
            each msg in info
              .alert.alert-info.alert-dismissible.fade.show(role="alert")
                i.bi.bi-info-circle.me-2
                = msg
                button.btn-close(type="button" data-bs-dismiss="alert")

          //- Page content injected here
          block content

    else
      //- Unauthenticated users see no navbar or sidebar
      block content

    //- Bootstrap JS
    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js")
    block scripts