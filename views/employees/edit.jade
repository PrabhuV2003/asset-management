extends ../layout

block content
    .d-flex.align-items-center.mb-4
        a.btn.btn-outline-secondary.me-3(href="/employees")
            i.bi.bi-arrow-left
        div
            h1.h3.fw-bold
                i.bi.bi-pencil-square.me-2.text-primary
                | Edit Employee
            p.text-muted.mb-0= employee.fullName

    .row
        .col-lg-8
            .card.border-0.shadow-sm
                .card-body.p-4

                    if errors && errors.length
                        .alert.alert-danger
                            ul.mb-0
                                each err in errors
                                    li= err

                    form(action='/employees/' + employee.id + '/edit' method="POST" novalidate)

                        h6.fw-semibold.text-muted.text-uppercase.mb-3 Profile Information

                        .row.g-3
                            .col-md-6
                                label.form-label.fw-semibold(for="fullName") Full Name *
                                input#fullName.form-control(
                                    type="text"
                                    name="fullName"
                                    value=employee.fullName
                                    required
                                )

                            .col-md-6
                                label.form-label.fw-semibold(for="email") Email Address *
                                input#email.form-control(
                                    type="email"
                                    name="email"
                                    value=employee.email
                                    required
                                )

                            .col-md-6
                                label.form-label.fw-semibold(for="phone") Phone Number
                                input#phone.form-control(
                                    type="tel"
                                    name="phone"
                                    value=employee.phone || ''
                                )

                            .col-md-6
                                label.form-label.fw-semibold(for="joinDate") Join Date
                                input#joinDate.form-control(
                                    type="date"
                                    name="joinDate"
                                    value=employee.joinDate || ''
                                )

                            .col-md-6
                                label.form-label.fw-semibold(for="department") Department
                                input#department.form-control(
                                    type="text"
                                    name="department"
                                    value=employee.department || ''
                                )

                            .col-md-6
                                label.form-label.fw-semibold(for="branch") Branch / Location
                                input#branch.form-control(
                                    type="text"
                                    name="branch"
                                    value=employee.branch || ''
                                )

                            .col-12
                                label.form-label.fw-semibold(for="designation") Designation
                                input#designation.form-control(
                                    type="text"
                                    name="designation"
                                    value=employee.designation || ''
                                )

                        hr.my-4

                        h6.fw-semibold.text-muted.text-uppercase.mb-3 System Access (Read-Only)

                        .row.g-3
                            .col-md-6
                                label.form-label.fw-semibold User ID
                                input.form-control.bg-light(
                                    type="text"
                                    value=employee.account ? employee.account.userId : 'No account'
                                    readonly
                                )
                                .form-text User IDs cannot be changed after creation.

                            .col-md-6
                                label.form-label.fw-semibold Role
                                input.form-control.bg-light(
                                    type="text"
                                    value=employee.account ? employee.account.role.replace(/_/g, ' ') : '—'
                                    readonly
                                )
                                .form-text To change a role, contact the system administrator.

                        .d-flex.gap-2.mt-4
                            button.btn.btn-primary(type="submit")
                                i.bi.bi-save.me-2
                                | Save Changes
                            a.btn.btn-outline-secondary(href="/employees") Cancel
