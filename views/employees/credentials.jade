extends ../layout

block content
    .row.justify-content-center
        .col-lg-6
            .card.border-0.shadow-lg(style="border-top: 4px solid #2563eb !important")
                .card-body.p-5.text-center

                    .mb-4
                        i.bi.bi-shield-lock-fill.text-primary(style="font-size: 3rem")
                        h1.h4.fw-bold.mt-3 Account Created Successfully
                        p.text-muted
                            | The Login Credentials For #[strong = credentials.fullName] Have Been Generated.
                            br
                            strong.text-danger This Page Will Not Be Shown Again. Save These Credentials Now.
                        
                        .alert.alert-warning.text-start
                            i.bi.bi-exclamation-triangle.me-2
                            | Share These Credentials Securely (In Person Or Via Encrypted Message). Do Not Send Via Plain Email.

                        .card.bg-light.border-0.text-start.mb-4
                            .card-body
                                .mb-3
                                    label.form-label.text-muted.small.fw-semibold.text-uppercase User ID
                                    .input-group
                                        input#credUserId.form-control.fw-bold(
                                            type="text"
                                            value=credentials.userId
                                            readonly
                                        )
                                        button.btn.btn-outline-secondary(
                                            type="button"
                                            onclick="copyToClipboard('credUserId')"
                                            title="Copy"
                                        )
                                            i.bi.bi-clipboard
                                
                                .mb-3
                                    label.form-label.text-muted.small.fw-semibold.text-uppercase Password
                                    .input-group
                                        input#credPassword.form-control.fw-bold(
                                            type="text"
                                            value=credentials.password
                                            readonly
                                        )
                                        button.btn.btn-outline-secondary(
                                            type='button'
                                            onclick="copyToClipboard('credPassword')"
                                            title="copy"
                                        )
                                            i.bi.bi-clipboard
                                
                                .mb-0
                                    label.form-label.text-muted.small.fw-semibold.text-uppercase Role
                                    p.fw-bold.mb-0= credentials.role.replace(/_/g, ' ').replace(/\b\w/g, c=> c.toUpperCase())

                        .d-flex.gap-2.justify-content-center
                            a.btn.btn-primary(href='/employees/new')
                                i.bi.bi-person-plus.me-2
                                | Add Another Employee
                            a.btn.btn-outline-secondary(href='/employees')
                                i.bi.bi-people.me-2
                                | Back To List

block scripts
    script. 
        function copyToClipboard(inputId) {
            const input = document.getElementById(inputId);
            navigator.clipboard.writeText(input.value).then(() =>  {
                const btn = input.nextElementSibling;
                btn.innerHTML = '<i class="bi bi-check-lg"></i>';
                btn.classList.replace('btn-outline-secondary', 'btn-success');
                setTimeout(() => {
                    btn.innerHTML = '<i class="bi bi-clipboard"></i>';
                    btn.classList.replace('btn-success', 'btn-outline-secondary')
                }, 1500);
            })
        }